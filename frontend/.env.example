# PageSpeed Insights API (optional — avoids 429 on PSI; pass as key= query param)
# GOOGLE_PAGESPEED_API_KEY=
# PAGE_SPEED_INSIGHTS_API=   # alias used in some deployments (same Google API key value)

# used for sitemap.ts , robots.ts , and for client.ts
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# used for Draft Mode (Open in Studio Url)
NEXT_PUBLIC_STUDIO_URL=http://localhost:3333
# used for metadata to set robots (you can set development for you testing subdomain)
NEXT_PUBLIC_SITE_ENV=development
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-P0DQM5CH0D
# backward-compatible alias (optional if old env already exists)
# NEXT_PUBLIC_GA_ID=G-P0DQM5CH0D
# Resend to send contact form submissions
RESEND_API_KEY=replace-with-resend-api-key
NEXT_RESEND_TO_EMAIL=team@example.com
NEXT_RESEND_FROM_EMAIL=noreply@example.com

# SANITY CMS
# use current date (YYYY-MM-DD) to target the latest API version
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_SANITY_PROJECT_ID=replace-with-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=replace-with-read-token

# Localhost or live site for preview mode
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
SANITY_STUDIO_API_VERSION=2024-01-01
SANITY_STUDIO_PROJECT_ID=replace-with-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=sanity-nextjs-kotacom-studio
SANITY_AUTH_TOKEN=replace-with-write-token
SANITY_STUDIO_APP_ID=replace-with-studio-app-id
SANITY_DEV=replace-with-dev-token
SANITY_DEPLOY=replace-with-deploy-token

# Revalidate webhook
REVALIDATE_SECRET=replace-with-revalidate-secret

# SEO dashboard webhook (optional)
SEO_DASHBOARD_URL=https://seo-dashboard.example.com
SEO_DASHBOARD_WEBHOOK_SECRET=replace-with-dashboard-webhook-secret
