SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
SANITY_STUDIO_API_VERSION=2026-03-23
SANITY_STUDIO_PROJECT_ID=replace-with-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=replace-with-hostname
SANITY_AUTH_TOKEN=replace-with-deploy-token

# Optional auth override for agent/script mutations (dev token takes precedence)
SANITY_DEV=replace-with-sanity-dev-write-token
SANITY_DEPLOY=false
# Optional: legacy/advanced deploy target (normally not required in CI)
SANITY_STUDIO_APP_ID=replace-with-studio-app-id

# AI Writer Studio action (must match frontend AI_WRITER_ACTION_SECRET)
SANITY_STUDIO_AI_WRITER_ACTION_SECRET=replace-with-strong-shared-secret
