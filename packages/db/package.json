{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "db:setup": "node scripts/setup-database.mjs",
    "db:seed": "node scripts/seed-database.mjs",
    "db:reset": "node scripts/reset-database.mjs",
    "db:reset:seed": "node scripts/reset-database.mjs --yes && node scripts/seed-database.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3"
  }
}
