# ============================================
# PUBLIC CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=https://ops.example.com
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01
NEXT_PUBLIC_SANITY_USE_CDN=false
NEXT_PUBLIC_STUDIO_URL=https://your-studio-url

# ============================================
# SANITY AUTH
# ============================================
# Write token for Sanity operations
SANITY_AUTH_TOKEN=replace-with-sanity-write-token
# Dev write token (preferred for agent-driven ops)
SANITY_DEV=replace-with-dev-write-token
SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_VERSION=2026-04-01
SANITY_API_WRITE_TOKEN=replace-with-write-token

# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ============================================
# REDIS QUEUE (Upstash)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================
# DASHBOARD AUTH
# ============================================
SEO_SESSION_SECRET=replace-with-session-secret-min-32-chars
SEO_DASHBOARD_PASSWORD=replace-with-dashboard-password
SEO_DASHBOARD_PASSWORD_SHA256=replace-with-sha256-hash
SEO_SETTINGS_ENCRYPTION_KEY=replace-with-32-chars-secret

# ============================================
# AI PROVIDERS
# ============================================
# Gateway (Vercel AI SDK Gateway)
AI_GATEWAY_API_KEY=replace-with-ai-gateway-key
AI_GATEWAY_PROVIDER_ORDER=openai,anthropic,google
AI_GATEWAY_FALLBACK_MODELS=gpt-5.4,claude-sonnet-4.5,gemini-2.5-flash

# Groq (comma-separated keys for rotation)
AI_WRITER_GROQ_KEYS=key1,key2,key3

# Gemini (comma-separated keys for rotation)
AI_WRITER_GEMINI_KEYS=key1,key2,key3

# AI Routing Config
AI_ROUTING_ENABLED=true
AI_ROUTING_PROVIDER_ORDER=gateway,groq,gemini
AI_ROUTING_DEFAULT_MODEL_GATEWAY=gpt-5.4
AI_ROUTING_DEFAULT_MODEL_GROQ=meta-llama/llama-4-scout-17b-16e-instruct
AI_ROUTING_DEFAULT_MODEL_GEMINI=gemini-2.5-flash
AI_ROUTING_TEMPERATURE=0.7
AI_ROUTING_MAX_OUTPUT_TOKENS=4096

# ============================================
# GOOGLE SEARCH CONSOLE
# ============================================
GSC_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL=https://example.com

# ============================================
# INDEXNOW
# ============================================
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
INDEXNOW_KEY=your-indexnow-key
INDEXNOW_KEY_LOCATION=https://example.com/indexnow-key.txt

# ============================================
# INTERNAL API SECRETS
# ============================================
# Secret for worker cron → ops API
CRON_SECRET=replace-with-cron-secret-min-32-chars
# Secret for Sanity webhook → ops API
INTERNAL_API_SECRET=replace-with-internal-api-secret-min-32-chars
# Secret for ops → frontend revalidate
REVALIDATE_SECRET=replace-with-revalidate-secret

# ============================================
# FRONTEND INTEGRATION
# ============================================
# URL of frontend for revalidation callbacks
FRONTEND_REVALIDATE_URL=https://example.com/api/revalidate
