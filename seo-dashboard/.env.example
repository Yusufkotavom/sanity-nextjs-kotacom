# Sanity public config
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01
NEXT_PUBLIC_SANITY_USE_CDN=false
NEXT_PUBLIC_STUDIO_URL=https://your-studio-url

# Sanity write token (dev recommended)
SANITY_AUTH_TOKEN=replace-with-sanity-write-token
SANITY_DEV=replace-with-dev-write-token

# SEO dashboard auth
SEO_SESSION_SECRET=replace-with-session-secret
SEO_DASHBOARD_PASSWORD=replace-with-dashboard-password
SEO_DASHBOARD_PASSWORD_SHA256=replace-with-sha256-hash
SEO_SETTINGS_ENCRYPTION_KEY=replace-with-32-chars-secret

# AI Writer secrets
AI_GATEWAY_API_KEY=replace-with-ai-gateway-key
AI_WRITER_GEMINI_KEYS=key1,key2
AI_WRITER_GROQ_KEYS=key1,key2
