{
  "name": "schema-ui-next-js-sanity-starter",
  "version": "2.0.0",
  "description": "Schema UI: Next.js + Sanity Starter Template",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm run dev --workspace=frontend",
    "dev:studio": "pnpm run dev --workspace=studio",
    "dev:dashboard": "pnpm run dev --workspace=seo-dashboard",
    "typegen": "cd studio && pnpm typegen",
    "typecheck": "cd frontend && pnpm typecheck",
    "export": "cd studio && sanity dataset export production sample-data.tar.gz",
    "skill:ops:contract": "node frontend/scripts/ops-check-block-contract.mjs --json",
    "skill:content:generate": "node frontend/scripts/ops-generate-content-payload.mjs",
    "skill:content:validate": "node frontend/scripts/ops-validate-sanity-payload.mjs",
    "skill:content:upsert": "node frontend/scripts/ops-upsert-sanity-content.mjs",
    "skill:zip:daily-ops": "node scripts/build-repo-daily-ops-skill-zip.mjs",
    "skill:zip:content-ops": "node scripts/build-sanity-content-ops-skill-zip.mjs",
    "skill:zip:all": "pnpm run skill:zip:daily-ops && pnpm run skill:zip:content-ops",
    "skill:verify:integration": "node scripts/verify-skill-integration.mjs"
  },
  "homepage": "https://www.schemaui.com/"
}
